---
import experience from '../data/experience.json'
import education from '../data/education.json'
import about from '../data/about.json'
---


<!DOCTYPE html>
<html lang="en">

<head>
  <meta charSet="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.png" />

  <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@300&family=Lato:wght@300;400&display=swap"
    rel="stylesheet" />

  <title>Nabeel Valley - CV</title>

  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;600&family=Inconsolata:ital,wght@0,400;0,600;1,400;1,600&display=swap');


    html,body {
      background-color: black;

      font-family: 'Open Sans';
      font-optical-sizing: auto;
      font-style: normal;
      font-size: 12px;
    }

    main {
      color: hsl(260deg 100% 5%);
      --color-1: hsl(260deg 100% 40%);
      --color-2: hsl(260deg 100% 98%);

      margin: auto;

      background-color: white;
      display: flex;
      flex-direction: row;
      gap: 16px;

      height: 297mm;
      width: 210mm;
      box-sizing: border-box;

      padding: 32px;
      
      p, h3 {
          margin-top: 8px;
      }

      * {
        margin: 0;
        padding: 0;
        text-decoration: none;
      }

      
      hr {
        border: none;
        border-top: 1px var(--color-1) solid;
      }

      h2 {
        color: var(--color-1);
      }

      .timeline {
        flex: 2;

        display: flex;
        flex-direction: column;

        hr {
          margin: 32px 0 16px 0;
        }
 

        & .location {
          display: flex;
          flex-direction: row;
          align-items: center;
          gap: 8px;
        }
        
        & .summary {
          color: var(--color-1);
          display: flex;
          flex-direction: row;
          justify-content: space-between;
          margin-top: 4px;

          p {
            margin: 0;
          }
        }

        experiences {
          display: flex;
          flex-direction: column;
          gap: 8px;
        }

        educations {
          display: flex;
          flex-direction: row;
          gap: 16px;

          item {
            flex: 1;
          }
        }
      }
      
      a {
        color: var(--color-1)
      }

      li {
        margin-left: 12px;

        &::marker{
          color: var(--color-1);
        }
      }

      
      svg {
        display: block;
        height: 12px;
        width: 12px;
      }

      .intro {
        background-color: var(--color-2);

        flex: 1;
        padding: 16px;

        display: flex;
        flex-direction: column;
        gap: 8px;

        tagline {
          font-size: 1.2rem;
        }

        
        hr {
          margin: 12px 0;
        }

        & .skills{
          list-style-type: '# ';
          display: flex;
          flex-wrap: wrap;
        }

        & .contact {
          list-style: none;

          li {
            margin-left: 0;

            a {
              display: flex;
              flex-direction: row;
              align-items: center;              
              gap: 8px;
            }
          }
        }
      }
    }
  </style>
</head>

<body>
<main>
  <section class="intro">
    <h1>Nabeel Valley</h1>
    <tagline>{about.tagline}</tagline>
    <hr>
    <h2>About me</h2>
    <div class="about">
      {about.about.split('\n').map((p) => (
        <p>{p}</p>
      ))}
    </div>
    <h3>Contact</h3>

    <ul class="contact" role="list">
      <!-- icons from feathericons.com -->
      <li>
        <a href={`tel:${import.meta.env.PUBLIC_CONTACT_PHONE}`}>
          <svg role="image" aria-labelledby="phone" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {import.meta.env.PUBLIC_CONTACT_PHONE}
        </a>
      </li>
      <li>
        <a href={`mailto:${import.meta.env.PUBLIC_CONTACT_EMAIL}`}>
          <svg role="image" aria-labelledby="email" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-mail"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          {import.meta.env.PUBLIC_CONTACT_EMAIL}
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/nabeelvalley/">
          <svg role="image" aria-labelledby="linkedin" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          linkedin.com/in/nabeelvalley
        </a>
      </li>
      <li>
        <a href="https://nabeelvalley.co.za">
          <svg role="image" aria-labelledby="website" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-globe"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          nabeelvalley.co.za
        </a>
      </li>
    </ul>

    <h3>Languages</h3>

    <ul role="list" class="languages">
      {about.languages.map(l => l.length > 1
        ? <li>{l[0]} (<b>{l[1]}</b>)</li>
        : <li>{l[0]}</li>
      )}
    </ul>

    <h3>Certifications</h3>
    <ul role="list">
      {about.certifications.map(s => <li>{s}</li>)}
    </ul>

    <h3>Skills</h3>
    <ul role="list" class="skills">
      {about.skills.map(s => <li>{s}</li>)}
    </ul>
  </section>

  <section class="timeline">
    <h2>Experience</h2>
    <experiences>
    {
      experience.map((exp) => (
        <>
          <h3 class="title">{exp.company}</h3>
          <h4 class="subtitle">{exp.subtitle}</h4>
          <div class="summary">
            <p class="period">{exp.period}</p>
            <p class="location">
              {exp.location}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-map-pin"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </p>
          </div>
          {
            exp.full && <ul class="description">
              {exp.points.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          }
        </>
      ))
    }    
    </experiences>

    <hr>

    <h2>Education</h2>      
    <educations>
      {
        education.map((edu) => (
          <item>
            <h3 class="title">{edu.school}</h3>
            <h4 class="subtitle">{edu.qualification}</h4>
            <p class="summary">{edu.period}</p>
          </item>
        ))
      }
    </educations>
  </section>
</main>
</body>
