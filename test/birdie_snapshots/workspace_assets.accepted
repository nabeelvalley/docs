      <link href="/index.css" rel="stylesheet">
    </noscript>
    <script defer="true" src="/index.js" type="module"></script>
  </head>
  <body>
    <header>
      <h1>
        First Post
      </h1>
      <nav>
        <ul>
          <li>
            <a href="/special">
              special
            </a>
          </li>
          <li>
            <a href="/blog">
              blog
            </a>
          </li>
        </ul>
      </nav>
    </header>
    <main>
      <h2>
        Welcome!
      </h2>
      

      <p>
        This is some content in Markdown that can be rendered to your site
      </p>
      

      <p>
        Here&#39;s a code block and some other 
        <em>
          fancy
        </em>
         formatting
      </p>
      

      <pre>
        <code class="language-sh">
          gleam run

        </code>
      </pre>
      

      <pre>
        <code class="language-js">
          // some more complicated example
const data = {
  name: &quot;bob&quot;
}

function print(d){
  console.log(d)
}

print(data)

        </code>
      </pre>
      

    </main>
  </body>
</html>

