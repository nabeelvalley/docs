<html lang="en">
  <head>
    <title>
      First Post
    </title>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link href="/favicon.png" rel="icon" type="image/x-icon">
    <link href="/default.css" rel="stylesheet">
