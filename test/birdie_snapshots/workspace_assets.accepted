HTMLFile: /about.html
<html lang="en">
  <head>
    <title>
      Hello world!
    </title>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link href="/favicon.png" rel="icon" type="image/x-icon">
    <link href="/default.css" rel="stylesheet">
    <noscript>
      <link href="/index.css" rel="stylesheet">
    </noscript>
    <script defer="true" src="/index.js" type="module"></script>
  </head>
  <body>
    <header>
      <h1>
        Hello world!
      </h1>
      <nav>
        <ul>
          <li>
            <a href="/special">
              special
            </a>
          </li>
          <li>
            <a href="/blog">
              blog
            </a>
          </li>
        </ul>
      </nav>
    </header>
    <main>
      <h2>
        Welcome!
      </h2>
      

      <p>
        This is some content in Markdown that can be rendered to your site
      </p>
      

      <p>
        Here&#39;s a code block and some other 
        <em>
          fancy
        </em>
         formatting
      </p>
      

      <pre>
        <code class="language-sh">
          gleam run

        </code>
      </pre>
      

    </main>
  </body>
</html>

