{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": [
    "./src",
    "./client"
  ],
  "compilerOptions": {
    "types": [
      "@webgpu/types"
    ],
    "noEmit": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "esnext",
    "lib": [
      "DOM",
      "ESNext"
    ]
  }
}