{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": [
    "./src/**/*.mjs"
  ],
  "compilerOptions": {
    "noEmit": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext"
    ]
  }
}